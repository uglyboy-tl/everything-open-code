{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-wakatime"
  ],
  "model": "alibaba-coding-plan-cn/qwen3-coder-plus",
  "share": "disabled",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
  },
  "lsp": {
    "bash": {
      "disabled": true
    }
  },
  "disabled_providers": [
    "github-copilot",
    "github-copilot-enterprise",
    "github-models"
  ],
  "permission": {
    "external_directory": {
      "$HOME/Code/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "provider": {
    "google": {
      "options": {
        "baseURL": "https://xget.uglyboy.cn/ip/gemini/v1beta"
      },
    },
    "openrouter": {
      "options": {
        "baseURL": "https://xget.uglyboy.cn/ip/openrouter/api/v1"
      },
    },
    "n1n": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "n1n",
      "options": {
        "baseURL": "https://api.n1n.ai/v1"
      },
      "models": {
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        },
        "gpt-5.2": {
          "name": "GPT 5.2"
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        }
      }
    },
  }
}