{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-wakatime",
    "@tarquinen/opencode-dcp@latest"
  ],
  "instructions": [
    ".opencode/memory/MEMORY.md"
  ],
  "model": "opencode/deepseek-v4-flash-free",
  "share": "disabled",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "experimental": {
    "continue_loop_on_deny": true
  },
  "lsp": {},
  "disabled_providers": [
    "github-copilot",
    "github-copilot-enterprise",
    "github-models"
  ],
  "permission": {
    "external_directory": {
      "$HOME/Code/**": "allow",
      "/tmp/**": "allow"
    },
    "skill": {
      "anysearch": "deny"
    }
  },
  "provider": {
    "agnes": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Agnes",
      "options": {
        "baseURL": "https://apihub.agnes-ai.com/v1"
      },
      "models": {
        "agnes-2.0-flash": {
          "name": "Agnes 2.0 Flash"
        }
      }
    },
    "n1n": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "n1n",
      "options": {
        "baseURL": "https://api.n1n.ai/v1"
      },
      "models": {
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        },
        "gpt-5.2": {
          "name": "GPT 5.2"
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        }
      }
    }
  }
}